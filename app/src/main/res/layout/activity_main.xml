<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Top Toolbar - Adobe Style -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Dex PDF"
        app:titleTextColor="@color/on_primary" />

    <!-- Action Buttons Bar -->
    <HorizontalScrollView
        android:id="@+id/actionBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpen"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:text="@string/open_file"
                android:textColor="@color/primary"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_add"
                app:iconSize="18dp"
                app:iconTint="@color/primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddText"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:text="@string/add_text"
                android:textColor="@color/primary"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconSize="18dp"
                app:iconTint="@color/primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignature"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:text="@string/add_signature"
                android:textColor="@color/primary"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconSize="18dp"
                app:iconTint="@color/primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@color/divider" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:text="@string/save"
                android:textColor="@color/accent"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconSize="18dp"
                app:iconTint="@color/accent" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- PDF View Area -->
    <FrameLayout
        android:id="@+id/pdfContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/background"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/actionBar">

        <ImageView
            android:id="@+id/pdfPageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="PDF Page"
            android:scaleType="fitCenter" />

        <!-- Overlay per testo e firma -->
        <com.pdfeditor.app.OverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:alpha="0.4"
                android:contentDescription="No file"
                android:src="@android:drawable/ic_menu_agenda" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/no_file_open"
                android:textColor="@color/text_hint"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnPrevPage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous"
            android:src="@android:drawable/ic_media_previous" />

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            tools:text="Pagina 1 di 5" />

        <ImageButton
            android:id="@+id/btnNextPage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next"
            android:src="@android:drawable/ic_media_next" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
