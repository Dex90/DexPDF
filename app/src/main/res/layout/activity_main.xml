<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Dex PDF"
        app:titleTextColor="@color/on_primary" />

    <!-- Toolbar with clear icon labels -->
    <HorizontalScrollView
        android:id="@+id/actionBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpen"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Apri"
                android:textColor="@color/primary"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_add"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddText"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Testo"
                android:textColor="@color/primary"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddCheck"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Spunta"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold"
                app:icon="@android:drawable/checkbox_on_background"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignature"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Firma"
                android:textColor="@color/primary"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHighlight"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Evidenzia"
                android:textColor="#FFC107"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_gallery"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="#FFC107" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEraser"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Gomma"
                android:textColor="@color/primary"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOcr"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="OCR"
                android:textColor="@color/primary"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_view"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Salva"
                android:textColor="@color/accent"
                android:textSize="11sp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="top"
                app:iconSize="20dp"
                app:iconTint="@color/accent" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- PDF Area: PhotoView for zoom + Overlay on top -->
    <FrameLayout
        android:id="@+id/pdfContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#2A2A2A"
        app:layout_constraintBottom_toTopOf="@id/textInputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/actionBar">

        <com.github.chrisbanes.photoview.PhotoView
            android:id="@+id/pdfPageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="PDF Page"
            android:scaleType="fitCenter" />

        <com.pdfeditor.app.OverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:alpha="0.6"
                android:contentDescription="No file"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tocca Apri per caricare un PDF"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Text Input Bar - ELEVATED ABOVE PDF -->
    <LinearLayout
        android:id="@+id/textInputBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextDirect"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/edit_text_background"
            android:hint="Scrivi qui, poi tocca il PDF..."
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="@color/on_surface"
            android:textColorHint="#9E9E9E"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btnCancelText"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Annulla"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/on_surface" />
    </LinearLayout>

    <!-- Bottom page navigation -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnPrevPage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/on_surface" />

        <TextView
            android:id="@+id/tvPageIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            tools:text="Pagina 1 di 5" />

        <ImageButton
            android:id="@+id/btnNextPage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next"
            android:src="@android:drawable/ic_media_next"
            android:tint="@color/on_surface" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
